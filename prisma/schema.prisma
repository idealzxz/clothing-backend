generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 用户 ====================

model User {
  id                 Int      @id @default(autoincrement())
  userId             String   @unique
  openid             String   @unique
  nickname           String?
  avatarUrl          String?
  phone              String?
  status             Int      @default(1) // 1正常 2冻结 3注销
  agreementConfirmed Boolean  @default(false)
  agreementVersion   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  settings           UserSettings?
  pointsAccount      PointsAccount?
  generationTasks    GenerationTask[]
  pointsTransactions PointsTransaction[]
  works              Work[]
  inboxMessages      InboxMessage[]
  communityRecipes   CommunityRecipe[]
  recipeCollections  UserRecipeCollection[]
  orders             PointsOrder[]
}

model UserSettings {
  id                              Int      @id @default(autoincrement())
  userId                          String   @unique
  clarityDetectionEnabled         Boolean  @default(false)
  backgroundNoiseDetectionEnabled Boolean  @default(false)
  updatedAt                       DateTime @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

// ==================== 积分 ====================

model PointsAccount {
  id               Int      @id @default(autoincrement())
  userId           String   @unique
  availableBalance Int      @default(0)
  frozenBalance    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model PointsTransaction {
  id            Int      @id @default(autoincrement())
  transactionId String   @unique
  userId        String
  type          String
  amount        Int
  bizId         String
  balanceBefore Int
  balanceAfter  Int
  frozenBefore  Int
  frozenAfter   Int
  remark        String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([bizId])
}

model PointsRule {
  id          Int      @id @default(autoincrement())
  bizType     String
  resultType  String
  spec        String
  pointsCost  Int
  status      Boolean  @default(true)
  effectiveAt DateTime @default(now())

  @@unique([bizType, resultType, spec])
}

model PointsPackage {
  id             Int     @id @default(autoincrement())
  packageName    String
  originalPoints Int
  giftPoints     Int     @default(0)
  totalPoints    Int
  amount         Int // 单位：分
  status         Boolean @default(true)
}

// ==================== 订单 ====================

model PointsOrder {
  id             Int       @id @default(autoincrement())
  orderId        String    @unique
  userId         String
  packageId      Int?
  packageName    String
  originalPoints Int
  giftPoints     Int       @default(0)
  totalPoints    Int
  amount         Int
  status         String    @default("pending") // pending/paid/cancelled/closed/refunded
  payChannel     String?
  wechatTradeNo  String?
  wechatPaidAt   DateTime?
  createdAt      DateTime  @default(now())
  paidAt         DateTime?
  expiredAt      DateTime
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ==================== 预设 ====================

model ModelPreset {
  id              Int      @id @default(autoincrement())
  name            String
  source          String   @default("system")
  referenceImages Json
  gender          String
  ageRange        String
  bodyType        String
  styleTags       Json
  createdBy       String?
  createdAt       DateTime @default(now())

  templates TemplatePreset[]
}

model ScenePreset {
  id              Int      @id @default(autoincrement())
  name            String
  source          String   @default("system")
  referenceImages Json
  sceneType       String
  keywords        Json
  createdBy       String?
  createdAt       DateTime @default(now())

  templates TemplatePreset[]
}

model TemplatePreset {
  id            Int      @id @default(autoincrement())
  name          String
  category      String
  modelPresetId Int
  scenePresetId Int
  keywordTuning String?
  source        String   @default("system")
  isHot         Boolean  @default(false)
  coverImage    String?
  createdBy     String?
  createdAt     DateTime @default(now())

  modelPreset ModelPreset @relation(fields: [modelPresetId], references: [id])
  scenePreset ScenePreset @relation(fields: [scenePresetId], references: [id])
}

// ==================== 生成任务 ====================

model GenerationTask {
  id              Int      @id @default(autoincrement())
  taskId          String   @unique
  userId          String
  clientRequestId String
  taskType        String
  prompt          String?
  presetId        String
  ratio           String
  count           Int
  assets          Json
  status          String   @default("queued")
  providerTaskId  String?
  resultUrls      Json
  pointsCost      Int      @default(0)
  failedReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [userId], onDelete: Cascade)
  results TaskResult[]

  @@unique([userId, clientRequestId])
  @@index([userId, createdAt])
}

model TaskResult {
  id           Int      @id @default(autoincrement())
  resultId     String   @unique
  taskId       String
  resultType   String
  resultUrl    String
  thumbnailUrl String?
  qualityScore Float?
  isSelected   Boolean  @default(false)
  createdAt    DateTime @default(now())

  task GenerationTask @relation(fields: [taskId], references: [taskId], onDelete: Cascade)

  @@index([taskId])
}

// ==================== 作品库 ====================

model Work {
  id               Int      @id @default(autoincrement())
  workId           String   @unique
  userId           String
  taskId           String?
  resultId         String?
  resultType       String
  resultUrl        String
  thumbnailUrl     String?
  generationParams Json?
  title            String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ==================== 配方 ====================

model CommunityRecipe {
  id             Int      @id @default(autoincrement())
  recipeId       String   @unique
  userId         String
  recipeName     String
  coverImageUrl  String
  presetSnapshot Json
  category       String   @default("通用")
  useCount       Int      @default(0)
  status         String   @default("published")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User                   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  collections UserRecipeCollection[]

  @@index([status, useCount])
}

model UserRecipeCollection {
  id                   Int      @id @default(autoincrement())
  collectionId         String   @unique
  userId               String
  recipeId             String?
  sourceType           String   @default("self_created")
  customPresetSnapshot Json?
  recipeName           String
  createdAt            DateTime @default(now())

  user   User              @relation(fields: [userId], references: [userId], onDelete: Cascade)
  recipe CommunityRecipe?  @relation(fields: [recipeId], references: [recipeId])

  @@index([userId, createdAt])
}

// ==================== 消息 ====================

model InboxMessage {
  id          Int      @id @default(autoincrement())
  messageId   String   @unique
  userId      String
  messageType String
  title       String
  content     String
  bizType     String?
  bizId       String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ==================== 系统配置 ====================

model FeatureFlag {
  id          Int      @id @default(autoincrement())
  flagKey     String   @unique
  flagType    String   @default("global")
  enabled     Boolean  @default(true)
  userTier    String?
  whitelist   Json?
  description String?
  updatedAt   DateTime @updatedAt
}
