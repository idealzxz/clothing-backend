DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-jwt-secret"
JWT_EXPIRES_IN="7d"
PORT=3000

# ========== 即梦 AI 4.0 (火山引擎 CV 服务) ==========
# 在火山引擎控制台 -> 密钥管理 获取 Access Key / Secret Key
# API 使用 CVSync2AsyncSubmitTask / CVSync2AsyncGetResult 异步模式
# req_key = jimeng_t2i_v40，接口地址 visual.volcengineapi.com
JIMENG_ACCESS_KEY=""
JIMENG_SECRET_KEY=""

# ========== 微信小程序（正式登录时需要） ==========
WECHAT_APPID=""
WECHAT_APP_SECRET=""

# ========== 阿里云 OSS 存储 ==========
# 配置后上传走 OSS，不配则本地存储（uploads/ 目录）
OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET=""
# 自定义域名（可选），不填则用 OSS 默认 URL
OSS_BASE_URL=""

# 本地开发：复制本文件为 .env（.env 勿提交）。
# Docker / Jenkins：使用仓库中的 docker.env（见 docker-compose.yml）。
